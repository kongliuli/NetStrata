<hc:Window x:Class="NetStrata.Tray.Views.SettingsWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           Title="NetStrata 设置"
           Height="560" Width="540"
           WindowStartupLocation="CenterScreen"
           ResizeMode="NoResize"
           ShowTitle="True"
           FontFamily="Microsoft YaHei UI">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="140"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <TextBlock x:Name="HeaderText" Grid.Row="0" Grid.ColumnSpan="2" Text="设置"
               FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>

    <TextBlock x:Name="LangLabel" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="界面语言"/>
    <ComboBox x:Name="LangBox" Grid.Row="1" Grid.Column="1" Margin="0,4"
              hc:BorderElement.CornerRadius="6">
      <ComboBoxItem Content="中文" Tag="zh"/>
      <ComboBoxItem Content="English" Tag="en"/>
      <ComboBoxItem Content="自动（默认中文）" Tag="auto"/>
    </ComboBox>

    <TextBlock x:Name="ThemeLabel" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="外观主题"/>
    <ComboBox x:Name="ThemeBox" Grid.Row="2" Grid.Column="1" Margin="0,4"
              hc:BorderElement.CornerRadius="6">
      <ComboBoxItem Content="跟随系统" Tag="system"/>
      <ComboBoxItem Content="浅色" Tag="light"/>
      <ComboBoxItem Content="深色" Tag="dark"/>
    </ComboBox>

    <TextBlock x:Name="IntervalLabel" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="探测间隔 (ms)"/>
    <TextBox x:Name="IntervalBox" Grid.Row="3" Grid.Column="1" Margin="0,4"
             hc:BorderElement.CornerRadius="6"
             hc:InfoElement.Placeholder="60000"/>

    <TextBlock x:Name="TlsLabel" Grid.Row="4" Grid.Column="0" VerticalAlignment="Top" Margin="0,8,0,0" Text="TLS 栈目标"/>
    <TextBox x:Name="TlsTargetsBox" Grid.Row="4" Grid.Column="1" Margin="0,4" Height="72"
             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
             hc:BorderElement.CornerRadius="6"
             hc:InfoElement.Placeholder="每行一个主机名"/>

    <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Margin="0,12,0,0">
      <CheckBox x:Name="StartupCheck" Content="登录时启动 NetStrata"/>
      <CheckBox x:Name="StartMinimizedCheck" Margin="0,8,0,0"
                Content="启动时最小化到托盘（不弹出主窗口）"/>
    </StackPanel>

    <hc:Card Grid.Row="6" Grid.ColumnSpan="2" Margin="0,12,0,0" BorderThickness="1" Padding="12">
      <TextBlock x:Name="TargetsNote" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"
                 Text="自定义 Ping / HTTPS 目标请在「自定义目标」页添加或删除。"/>
    </hc:Card>

    <TextBlock x:Name="StatusText" Grid.Row="7" Grid.ColumnSpan="2" Margin="0,10,0,0"
               Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>

    <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button x:Name="CancelButton" Content="取消" Margin="0,0,8,0"
              Style="{StaticResource ButtonDefault}"
              hc:BorderElement.CornerRadius="6"
              MinHeight="36" Padding="14,0"
              VerticalContentAlignment="Center"
              Click="Cancel_Click"/>
      <Button x:Name="SaveButton" Content="保存"
              Style="{StaticResource ButtonPrimary}"
              hc:BorderElement.CornerRadius="6"
              MinHeight="36" Padding="16,0"
              VerticalContentAlignment="Center"
              Click="Save_Click"/>
    </StackPanel>
  </Grid>
</hc:Window>
