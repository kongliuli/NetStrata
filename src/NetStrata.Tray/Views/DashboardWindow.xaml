<Window x:Class="NetStrata.Tray.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetStrata Dashboard"
        Height="520" Width="640"
        MinHeight="400" MinWidth="480"
        Background="#0F1115"
        Foreground="#E8EAED"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock x:Name="TitleText" Grid.Row="0" FontSize="18" FontWeight="SemiBold"/>
    <Border x:Name="AlertsPanel" Grid.Row="1" Margin="0,8,0,0" Padding="8"
            Background="#3C2F1E" BorderBrush="#FBBC04" BorderThickness="1" CornerRadius="6"
            Visibility="Collapsed">
      <TextBlock x:Name="AlertsText" Foreground="#FBBC04" TextWrapping="Wrap"/>
    </Border>
    <TextBlock x:Name="HeadlineText" Grid.Row="2" Margin="0,8,0,12" Foreground="#9AA0A6" TextWrapping="Wrap"/>

    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
      <ItemsControl x:Name="LayersList">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Width="140" Margin="0,0,8,8" Padding="10" CornerRadius="8"
                    Background="#1A1D24" BorderThickness="2" BorderBrush="{Binding BorderBrush}">
              <StackPanel>
                <TextBlock Text="{Binding Layer}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding State}" Margin="0,4,0,0"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <TextBlock x:Name="ProxyText" Grid.Row="4" Margin="0,8,0,0" Foreground="#BDC1C6" TextWrapping="Wrap"/>
    <TextBlock x:Name="MetaText" Grid.Row="5" Margin="0,6,0,0" FontSize="12" Foreground="#9AA0A6"/>
    <Button Grid.Row="6" Content="刷新" Margin="0,12,0,0" Padding="12,6" HorizontalAlignment="Left"
            Click="Refresh_Click"/>
  </Grid>
</Window>
