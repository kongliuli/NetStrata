<hc:Window x:Class="NetStrata.Tray.Views.MainWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           xmlns:controls="clr-namespace:NetStrata.Tray.Views.Controls"
           Title="NetStrata"
           Height="820" Width="1080"
           MinHeight="560" MinWidth="720"
           WindowStartupLocation="CenterScreen"
           ShowTitle="True"
           FontFamily="Microsoft YaHei UI"
           SizeChanged="Window_SizeChanged">
  <hc:Window.Resources>
    <Style x:Key="NsMuted" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style x:Key="NsPageTitle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="18"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>
    <Style x:Key="NsMetricLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Margin" Value="0,0,0,2"/>
    </Style>
    <Style x:Key="NsMetricValue" TargetType="TextBlock">
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style x:Key="NsStatusTag" TargetType="hc:Tag">
      <Setter Property="ShowCloseButton" Value="False"/>
      <Setter Property="Padding" Value="8,2"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style x:Key="NsProbeButton" TargetType="Button" BasedOn="{StaticResource ButtonPrimary}">
      <Setter Property="hc:BorderElement.CornerRadius" Value="10"/>
      <Setter Property="Height" Value="42"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style x:Key="NsToolButton" TargetType="Button" BasedOn="{StaticResource ButtonDefault}">
      <Setter Property="hc:BorderElement.CornerRadius" Value="10"/>
      <Setter Property="Height" Value="36"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Background" Value="{DynamicResource RegionBrush}"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
  </hc:Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="208"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- Growl host (W11b): in-window probe/refresh toasts -->
    <StackPanel Grid.Column="0" Grid.ColumnSpan="2"
                VerticalAlignment="Top" HorizontalAlignment="Right"
                Margin="0,16,16,0" Panel.ZIndex="100"
                hc:Growl.GrowlParent="True"/>

    <!-- Left nav: no hard divider; soft region contrast only -->
    <Border Grid.Column="0" BorderThickness="0"
            Background="{DynamicResource SecondaryRegionBrush}">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="16,18,16,12">
          <TextBlock Text="NetStrata" FontSize="18" FontWeight="SemiBold"/>
          <TextBlock x:Name="HeaderSubtitle" Text="分层网络健康" Margin="0,4,0,0"
                     Style="{StaticResource NsMuted}"/>
        </StackPanel>
        <Border DockPanel.Dock="Bottom" Margin="12,0,12,16" Padding="0,12,0,0"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
          <StackPanel>
            <hc:ProgressButton x:Name="ProbeButton" Content="立即探测"
                              Style="{StaticResource ProgressButtonPrimary}"
                              Height="42" FontSize="14" FontWeight="SemiBold"
                              hc:BorderElement.CornerRadius="10"
                              Click="Probe_Click"/>
            <UniformGrid Columns="2" Margin="0,8,0,0">
              <Button x:Name="RefreshButton" Content="刷新" Margin="0,0,4,0"
                      Style="{StaticResource NsToolButton}"
                      Click="Refresh_Click"/>
              <Button x:Name="SettingsButton" Content="设置" Margin="4,0,0,0"
                      Style="{StaticResource NsToolButton}"
                      Click="Settings_Click"/>
            </UniformGrid>
          </StackPanel>
        </Border>
        <hc:SideMenu x:Name="NavMenu" ExpandMode="ShowAll"
                     SelectionChanged="NavMenu_SelectionChanged"
                     Margin="4,0,4,0" Background="Transparent">
          <hc:SideMenuItem x:Name="NavOverview" Header="总览" Tag="overview" IsSelected="True"/>
          <hc:SideMenuItem x:Name="NavChain" Header="探测链路" Tag="chain"/>
          <hc:SideMenuItem x:Name="NavAi" Header="AI / API" Tag="ai"/>
          <hc:SideMenuItem x:Name="NavTargets" Header="自定义目标" Tag="targets"/>
          <hc:SideMenuItem x:Name="NavTrend" Header="历史趋势" Tag="trend"/>
          <hc:SideMenuItem x:Name="NavAlerts" Tag="alerts">
            <hc:SideMenuItem.Header>
              <hc:Badge x:Name="AlertsBadge" Value="0" Visibility="Collapsed"
                        BadgeMargin="0,-6,-10,0">
                <TextBlock x:Name="NavAlertsText" Text="通知告警" VerticalAlignment="Center"/>
              </hc:Badge>
            </hc:SideMenuItem.Header>
          </hc:SideMenuItem>
          <hc:SideMenuItem x:Name="NavLocal" Header="本机网络" Tag="local"/>
        </hc:SideMenu>
      </DockPanel>
    </Border>

    <!-- Pages -->
    <Grid Grid.Column="1" Margin="16">
      <!-- Overview -->
      <Grid x:Name="PageOverview">
      <ScrollViewer x:Name="OverviewScroller" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <hc:Card Margin="0,0,0,12" BorderThickness="1" Padding="16">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Border x:Name="OverallBadge" Grid.Column="0" MinWidth="76" Padding="14,10" Margin="0,0,14,0"
                      CornerRadius="10" VerticalAlignment="Top"
                      Background="{DynamicResource NsStatusOkSoftBrush}"
                      BorderBrush="{DynamicResource NsStatusOkBrush}" BorderThickness="1">
                <TextBlock x:Name="OverviewOverallBadge" Text="健康" FontSize="15" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource NsStatusOkBrush}"/>
              </Border>
              <StackPanel Grid.Column="1">
                <TextBlock x:Name="OverviewTitle" FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap"/>
                <TextBlock x:Name="OverviewHeadline" Margin="0,5,0,0" Style="{StaticResource NsMuted}" TextWrapping="Wrap"/>
                <TextBlock x:Name="OverviewAiHeadline" Margin="0,7,0,0" FontSize="12"
                           Foreground="{DynamicResource PrimaryBrush}" TextWrapping="Wrap"/>
                <TextBlock x:Name="OverviewMeta" Margin="0,8,0,0" FontSize="11"
                           Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
              </StackPanel>
            </Grid>
          </hc:Card>

          <hc:Card x:Name="AlertsPanel" Margin="0,0,0,12" BorderThickness="1" Padding="10,8"
                   Background="{DynamicResource WarningBrush}" Visibility="Collapsed">
            <StackPanel>
              <DockPanel Margin="2,0,2,6">
                <TextBlock x:Name="AlertsPanelTitle" DockPanel.Dock="Left" FontWeight="SemiBold" FontSize="13"
                           Text="近期通知" VerticalAlignment="Center"/>
                <TextBlock x:Name="AlertsMoreHint" DockPanel.Dock="Right" Margin="12,0,0,0"
                           VerticalAlignment="Center" FontSize="11" Opacity="0.9"
                           Cursor="Hand" Text="查看全部 →"
                           MouseLeftButtonUp="AlertsPanel_Click"/>
              </DockPanel>
              <!-- newest first, max 5; click expander header for detail -->
              <ItemsControl x:Name="OverviewAlertsList">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Expander Margin="0,0,0,4" BorderThickness="0" Padding="0"
                              IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                      <Expander.Header>
                        <DockPanel Margin="0,2">
                          <TextBlock DockPanel.Dock="Right" Text="{Binding When}" Margin="10,0,0,0"
                                     FontSize="11" Opacity="0.85" VerticalAlignment="Center"/>
                          <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                     TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </DockPanel>
                      </Expander.Header>
                      <TextBlock Text="{Binding Detail}" Margin="28,2,8,6" FontSize="12"
                                 TextWrapping="Wrap" Opacity="0.92"/>
                    </Expander>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </hc:Card>

          <hc:Card Margin="0,0,0,12" BorderThickness="1" Padding="4,2,4,10">
            <Expander x:Name="LayersExpander" IsExpanded="True" BorderThickness="0"
                      Expanded="Section_ExpandedChanged" Collapsed="Section_ExpandedChanged">
              <Expander.Header>
                <TextBlock x:Name="LayersTitle" FontWeight="SemiBold" FontSize="13" Margin="8,0,0,0"/>
              </Expander.Header>
              <ItemsControl x:Name="LayersList" Margin="8,4,8,0">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <hc:UniformSpacingPanel Orientation="Horizontal" Spacing="8" ChildWrapping="Wrap"
                                            HorizontalAlignment="Stretch"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <!-- W11c F1: click layer → probe chain -->
                    <Border MinWidth="108" Padding="10,8" CornerRadius="8" Cursor="Hand"
                            Background="{DynamicResource RegionBrush}"
                            MouseLeftButtonUp="LayerCard_Click"
                            MouseEnter="Card_MouseEnter" MouseLeave="Card_MouseLeave"
                            ToolTip="{Binding Detail}">
                      <DockPanel>
                        <Border DockPanel.Dock="Left" Width="3" CornerRadius="2" Margin="0,0,10,0"
                                Background="{Binding AccentBrush}" VerticalAlignment="Stretch"/>
                        <StackPanel>
                          <TextBlock Text="{Binding Title}" FontSize="11"
                                     Foreground="{DynamicResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis"/>
                          <TextBlock Text="{Binding Subtitle}" Margin="0,4,0,0" FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                      </DockPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Expander>
          </hc:Card>

          <!-- W11e F5: overview keeps summaries; detail lists live on dedicated pages -->
          <hc:Card Margin="0,0,0,12" BorderThickness="1" Padding="14,12" Cursor="Hand"
                   MouseLeftButtonUp="GotoAi_Click" MouseEnter="Card_MouseEnter" MouseLeave="Card_MouseLeave">
            <DockPanel>
              <TextBlock x:Name="OverviewAiMore" DockPanel.Dock="Right" Margin="12,0,0,0"
                         VerticalAlignment="Center" FontSize="11" Cursor="Hand"
                         Foreground="{DynamicResource PrimaryBrush}" Text="详情 →"/>
              <StackPanel>
                <TextBlock x:Name="OverviewAiTitle" FontWeight="SemiBold" FontSize="13"/>
                <TextBlock x:Name="OverviewAiSummary" Margin="0,6,0,0" FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
              </StackPanel>
            </DockPanel>
          </hc:Card>

          <hc:Card x:Name="OverviewTargetsExpanderHost" Margin="0,0,0,12" BorderThickness="1"
                   Padding="14,12" Cursor="Hand"
                   MouseLeftButtonUp="GotoTargets_Click"
                   MouseEnter="Card_MouseEnter" MouseLeave="Card_MouseLeave">
            <DockPanel>
              <TextBlock x:Name="OverviewTargetsMore" DockPanel.Dock="Right" Margin="12,0,0,0"
                         VerticalAlignment="Center" FontSize="11"
                         Foreground="{DynamicResource PrimaryBrush}" Text="详情 →"/>
              <StackPanel>
                <TextBlock x:Name="OverviewTargetsTitle" FontWeight="SemiBold" FontSize="13"/>
                <TextBlock x:Name="OverviewTargetsSummary" Margin="0,6,0,0" FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
              </StackPanel>
            </DockPanel>
          </hc:Card>

          <hc:Card x:Name="OverviewLocalExpanderHost" Margin="0,0,0,4" BorderThickness="1"
                   Padding="14,12" Cursor="Hand"
                   MouseLeftButtonUp="GotoLocal_Click"
                   MouseEnter="Card_MouseEnter" MouseLeave="Card_MouseLeave">
            <DockPanel>
              <TextBlock x:Name="OverviewLocalMore" DockPanel.Dock="Right" Margin="12,0,0,0"
                         VerticalAlignment="Center" FontSize="11"
                         Foreground="{DynamicResource PrimaryBrush}" Text="详情 →"/>
              <StackPanel>
                <TextBlock x:Name="OverviewLocalTitle" FontWeight="SemiBold" FontSize="13"/>
                <TextBlock x:Name="OverviewLocalSummary" Margin="0,6,0,0" FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
              </StackPanel>
            </DockPanel>
          </hc:Card>
        </StackPanel>
      </ScrollViewer>
      <hc:GotoTop AutoHiding="True" Target="{Binding ElementName=OverviewScroller}"
                  HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,8"/>
      </Grid>

      <!-- Chain -->
      <ScrollViewer x:Name="PageChain" Visibility="Collapsed"
                    VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <TextBlock Style="{StaticResource NsPageTitle}" Text="探测链路"/>
          <hc:Card Margin="0,0,0,12" BorderThickness="1" Padding="14">
            <StackPanel>
              <TextBlock x:Name="ChainOverall" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap"/>
              <TextBlock x:Name="ChainAi" Margin="0,6,0,0" Foreground="{DynamicResource PrimaryBrush}" TextWrapping="Wrap"/>
              <TextBlock x:Name="ChainMeta" Margin="0,8,0,0" Style="{StaticResource NsMuted}" TextWrapping="Wrap"/>
              <!-- W9f: compact shared-path strip (replaces per-layer ChainList cards) -->
              <TextBlock x:Name="TrunkHint" Margin="0,12,0,6" FontSize="11" FontWeight="SemiBold"
                         Text="公共路径"/>
              <!-- W11c F2: keep status colors; Poptip restores Reasons/Metrics -->
              <ItemsControl x:Name="TrunkStrip">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,0,8,6" Padding="10,6" CornerRadius="8" BorderThickness="1"
                            BorderBrush="{Binding AccentBrush}" Background="{Binding BadgeBg}"
                            ToolTip="{Binding Tip}">
                      <StackPanel>
                        <StackPanel Orientation="Horizontal">
                          <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12"
                                     VerticalAlignment="Center"/>
                          <TextBlock Text="{Binding Badge}" Margin="8,0,0,0" FontSize="11" FontWeight="SemiBold"
                                     Foreground="{Binding AccentBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Reasons}" Margin="0,3,0,0" FontSize="10" MaxWidth="200"
                                   TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Visibility="{Binding ReasonsVisibility}"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </hc:Card>
          <hc:Card Margin="0,0,0,12" BorderThickness="1" Padding="14">
            <controls:NetworkFlowControl x:Name="NetworkFlow"/>
          </hc:Card>
        </StackPanel>
      </ScrollViewer>

      <!-- AI -->
      <ScrollViewer x:Name="PageAi" Visibility="Collapsed"
                    VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <hc:Card BorderThickness="1">
          <Expander x:Name="AiExpander" IsExpanded="True" BorderThickness="0"
                    Expanded="Section_ExpandedChanged" Collapsed="Section_ExpandedChanged">
            <Expander.Header>
              <StackPanel>
                <TextBlock x:Name="AiTitle" FontWeight="SemiBold" FontSize="13"/>
                <TextBlock x:Name="AiHint" FontSize="11" Margin="0,2,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
              </StackPanel>
            </Expander.Header>
            <ItemsControl x:Name="AiList" Margin="8,8,8,0">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <hc:UniformSpacingPanel Orientation="Horizontal" Spacing="10" ChildWrapping="Wrap"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <hc:Card Width="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl}, Path=Tag}"
                           MinWidth="160" MaxWidth="420" BorderThickness="1" Padding="14,12"
                           Cursor="Hand"
                           MouseLeftButtonUp="Card_MouseLeftButtonUp"
                           MouseEnter="Card_MouseEnter" MouseLeave="Card_MouseLeave">
                    <hc:Card.ContextMenu>
                      <ContextMenu DataContext="{Binding Path=PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="打开官网" Click="OpenBrowser_Click" Visibility="{Binding OpenVisible}"/>
                        <MenuItem Header="复制官网 URL" Click="CopyUrl_Click" Visibility="{Binding OpenVisible}"/>
                      </ContextMenu>
                    </hc:Card.ContextMenu>
                    <StackPanel>
                      <DockPanel LastChildFill="True">
                        <hc:Tag DockPanel.Dock="Right" Style="{StaticResource NsStatusTag}" Content="{Binding Badge}"
                                Margin="8,0,0,0" Background="{Binding BadgeBg}" Foreground="{Binding AccentBrush}"
                                BorderBrush="{Binding AccentBrush}"/>
                        <StackPanel Orientation="Horizontal">
                          <Border Width="8" Height="8" CornerRadius="4" Margin="0,0,8,0"
                                  Background="{Binding AccentBrush}" VerticalAlignment="Center"/>
                          <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"
                                     VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                      </DockPanel>
                      <TextBlock Text="{Binding Detail}" Margin="0,10,0,0" FontSize="12"
                                 Foreground="{DynamicResource SecondaryTextBrush}"
                                 TextWrapping="Wrap" Visibility="{Binding Level2Visible}"/>
                      <Border Margin="0,12,0,0" Padding="10,8" CornerRadius="8"
                              Background="{DynamicResource RegionBrush}"
                              Visibility="{Binding Level3Visible}">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                          </Grid.ColumnDefinitions>
                          <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="{Binding DirectLabel}" Style="{StaticResource NsMetricLabel}"/>
                            <TextBlock Text="{Binding DirectValue}" Style="{StaticResource NsMetricValue}"/>
                          </StackPanel>
                          <Border Grid.Column="1" Width="1" Background="{DynamicResource BorderBrush}" Margin="0,2"/>
                          <StackPanel Grid.Column="2" Margin="10,0,0,0">
                            <TextBlock Text="{Binding ProxyLabel}" Style="{StaticResource NsMetricLabel}"/>
                            <TextBlock Text="{Binding ProxyValue}" Style="{StaticResource NsMetricValue}"/>
                          </StackPanel>
                        </Grid>
                      </Border>
                    </StackPanel>
                  </hc:Card>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Expander>
        </hc:Card>
      </ScrollViewer>

      <!-- Targets -->
      <ScrollViewer x:Name="PageTargets" Visibility="Collapsed"
                    VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <TextBlock x:Name="TargetsTitle" Style="{StaticResource NsPageTitle}"/>
          <TextBlock x:Name="TargetsHint" Style="{StaticResource NsMuted}" Margin="0,0,0,12" TextWrapping="Wrap"/>
          <hc:Card Margin="0,0,0,12" BorderThickness="1" Padding="12">
            <DockPanel>
              <Button x:Name="AddTargetButton" DockPanel.Dock="Right" Content="添加" Margin="10,0,0,0"
                      Style="{StaticResource ButtonPrimary}"
                      hc:BorderElement.CornerRadius="6"
                      MinHeight="36" Padding="16,0"
                      VerticalContentAlignment="Center"
                      Click="AddTarget_Click"/>
              <TextBox x:Name="TargetInput" MinHeight="36" Padding="10,0" VerticalContentAlignment="Center"
                       hc:BorderElement.CornerRadius="6"
                       hc:InfoElement.Placeholder="主机 IP 或 https://URL"/>
            </DockPanel>
          </hc:Card>
          <hc:Card x:Name="TargetsEmptyPanel" BorderThickness="1" Padding="20" Margin="0,0,0,8"
                   Visibility="Collapsed">
            <TextBlock x:Name="TargetsEmpty" Foreground="{DynamicResource SecondaryTextBrush}"
                       TextWrapping="Wrap" HorizontalAlignment="Center"/>
          </hc:Card>
          <ItemsControl x:Name="TargetsList">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <hc:UniformSpacingPanel Orientation="Horizontal" Spacing="10" ChildWrapping="Wrap"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <hc:Card Width="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl}, Path=Tag}"
                         MinWidth="160" MaxWidth="360" BorderThickness="1" Padding="14,12"
                         Cursor="Hand"
                         MouseLeftButtonUp="Card_MouseLeftButtonUp"
                         MouseEnter="Card_MouseEnter" MouseLeave="Card_MouseLeave">
                  <hc:Card.ContextMenu>
                    <ContextMenu DataContext="{Binding Path=PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                      <MenuItem Header="在浏览器打开" Click="OpenBrowser_Click" Visibility="{Binding OpenVisible}"/>
                      <MenuItem Header="复制 URL" Click="CopyUrl_Click" Visibility="{Binding OpenVisible}"/>
                      <MenuItem Header="删除目标" Click="RemoveTarget_Click" Visibility="{Binding RemoveVisible}"/>
                    </ContextMenu>
                  </hc:Card.ContextMenu>
                  <DockPanel>
                    <Border DockPanel.Dock="Left" Width="3" CornerRadius="2" Margin="0,0,12,0"
                            Background="{Binding AccentBrush}" VerticalAlignment="Stretch"/>
                    <hc:Tag DockPanel.Dock="Right" Style="{StaticResource NsStatusTag}" Content="{Binding Badge}"
                            Margin="12,0,0,0" Background="{Binding BadgeBg}" Foreground="{Binding AccentBrush}"
                            BorderBrush="{Binding AccentBrush}" VerticalAlignment="Top"/>
                    <StackPanel>
                      <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="{Binding Subtitle}" Margin="0,4,0,0" FontSize="12"
                                 Foreground="{DynamicResource SecondaryTextBrush}"
                                 TextWrapping="Wrap" Visibility="{Binding Level2Visible}"/>
                    </StackPanel>
                  </DockPanel>
                </hc:Card>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>

      <!-- Trend -->
      <ScrollViewer x:Name="PageTrend" Visibility="Collapsed"
                    VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <DockPanel Margin="0,0,0,12">
            <TextBlock x:Name="TrendTitle" Style="{StaticResource NsPageTitle}" DockPanel.Dock="Left"
                       VerticalAlignment="Center" Margin="0"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
              <RadioButton x:Name="Trend1h" Content="1h" GroupName="TrendWindow" Margin="0,0,8,0"
                           IsChecked="True" Checked="TrendWindow_Changed"/>
              <RadioButton x:Name="Trend6h" Content="6h" GroupName="TrendWindow" Margin="0,0,8,0"
                           Checked="TrendWindow_Changed"/>
              <RadioButton x:Name="Trend24h" Content="24h" GroupName="TrendWindow"
                           Checked="TrendWindow_Changed"/>
            </StackPanel>
          </DockPanel>
          <Border x:Name="TrendFocusBanner" Margin="0,0,0,12" Padding="10,8" CornerRadius="6"
                  Background="{DynamicResource NsStatusInfoSoftBrush}"
                  BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1"
                  Visibility="Collapsed">
            <TextBlock x:Name="TrendFocusHint" FontSize="12" TextWrapping="Wrap"
                       Foreground="{DynamicResource PrimaryBrush}"/>
          </Border>
          <hc:Card Margin="0,0,0,12" BorderThickness="1" Padding="12">
            <StackPanel>
              <TextBlock x:Name="TrendPingTitle" Text="Ping 延迟 (ms)" FontWeight="SemiBold" Margin="0,0,0,8"/>
              <ContentControl x:Name="TrendPingHost" Height="220"/>
            </StackPanel>
          </hc:Card>
          <hc:Card BorderThickness="1" Padding="12">
            <StackPanel>
              <TextBlock x:Name="TrendLayerHint" Text="分层状态时间线"
                         FontWeight="SemiBold" Margin="0,0,0,8"/>
              <!-- ponytail: discrete ok/degraded/fail → heat strip, not line chart -->
              <StackPanel x:Name="TrendLayerStrips"/>
              <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Border Width="12" Height="12" Margin="0,0,4,0"
                        Background="{DynamicResource NsStatusOkBrush}" CornerRadius="2"/>
                <TextBlock x:Name="TrendLegendOk" Text="正常" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="11"/>
                <Border Width="12" Height="12" Margin="0,0,4,0"
                        Background="{DynamicResource NsStatusDegradedBrush}" CornerRadius="2"/>
                <TextBlock x:Name="TrendLegendDegraded" Text="降级" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="11"/>
                <Border Width="12" Height="12" Margin="0,0,4,0"
                        Background="{DynamicResource NsStatusFailBrush}" CornerRadius="2"/>
                <TextBlock x:Name="TrendLegendFail" Text="失败" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="11"/>
                <Border Width="12" Height="12" Margin="0,0,4,0"
                        Background="{DynamicResource NsStatusSkippedBrush}" CornerRadius="2"/>
                <TextBlock x:Name="TrendLegendSkip" Text="跳过/未知" VerticalAlignment="Center" FontSize="11"/>
              </StackPanel>
            </StackPanel>
          </hc:Card>
          <TextBlock x:Name="TrendEmpty" Margin="0,12,0,0" Style="{StaticResource NsMuted}"
                     TextWrapping="Wrap" Visibility="Collapsed"/>
        </StackPanel>
      </ScrollViewer>

      <!-- Alerts (persisted history, plain-language) -->
      <ScrollViewer x:Name="PageAlerts" Visibility="Collapsed"
                    VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <DockPanel Margin="0,0,0,8">
            <TextBlock x:Name="AlertsTitle" Style="{StaticResource NsPageTitle}" DockPanel.Dock="Left"
                       VerticalAlignment="Center" Margin="0"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
              <RadioButton x:Name="AlertFilterAll" Content="全部" GroupName="AlertSeverity"
                           IsChecked="True" Margin="0,0,10,0" Checked="AlertFilter_Changed"/>
              <RadioButton x:Name="AlertFilterFail" Content="重要" GroupName="AlertSeverity"
                           Margin="0,0,10,0" Checked="AlertFilter_Changed"/>
              <RadioButton x:Name="AlertFilterWarn" Content="提醒" GroupName="AlertSeverity"
                           Margin="0,0,10,0" Checked="AlertFilter_Changed"/>
              <RadioButton x:Name="AlertFilterInfo" Content="提示" GroupName="AlertSeverity"
                           Checked="AlertFilter_Changed"/>
            </StackPanel>
          </DockPanel>
          <TextBlock x:Name="AlertsPageHint" Style="{StaticResource NsMuted}" Margin="0,0,0,12"
                     TextWrapping="Wrap"
                     Text="这里用白话记录网络变化（代理出口、路由器、网卡等），方便非专业用户对照。"/>
          <hc:Card x:Name="AlertsEmptyPanel" BorderThickness="1" Padding="20" Margin="0,0,0,8"
                   Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock x:Name="AlertsEmpty" Foreground="{DynamicResource SecondaryTextBrush}"
                         TextWrapping="Wrap" TextAlignment="Center" MaxWidth="420"/>
              <Button x:Name="AlertsEmptyProbeButton" Content="立即探测" Margin="0,14,0,0"
                      Style="{StaticResource NsProbeButton}" MinWidth="160"
                      HorizontalAlignment="Center"
                      Click="Probe_Click"/>
            </StackPanel>
          </hc:Card>
          <ItemsControl x:Name="AlertsList">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <hc:UniformSpacingPanel Orientation="Vertical" Spacing="8"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Padding="14,12" CornerRadius="8" BorderThickness="1"
                        BorderBrush="{Binding AccentBrush}"
                        Background="{DynamicResource RegionBrush}">
                  <Expander BorderThickness="0" IsExpanded="False">
                    <Expander.Header>
                      <DockPanel>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding When}" Margin="12,0,0,0"
                                   FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                                   VerticalAlignment="Center"/>
                        <hc:Tag DockPanel.Dock="Right" Style="{StaticResource NsStatusTag}"
                                Content="{Binding Badge}" Margin="8,0,12,0"
                                Background="{Binding BadgeBg}" Foreground="{Binding AccentBrush}"
                                BorderBrush="{Binding AccentBrush}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal">
                          <Border Width="3" Height="16" CornerRadius="2" Margin="0,0,10,0"
                                  Background="{Binding AccentBrush}" VerticalAlignment="Center"/>
                          <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"
                                     TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </StackPanel>
                      </DockPanel>
                    </Expander.Header>
                    <TextBlock Text="{Binding Detail}" Margin="16,6,0,2" FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>
                  </Expander>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>

      <!-- Local -->
      <ScrollViewer x:Name="PageLocal" Visibility="Collapsed"
                    VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <TextBlock x:Name="LocalTitle" Style="{StaticResource NsPageTitle}"/>
          <hc:Card BorderThickness="1" Padding="8">
            <ItemsControl x:Name="LocalList">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <hc:UniformSpacingPanel Orientation="Vertical" Spacing="2"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Padding="10,8" CornerRadius="6"
                          Background="{DynamicResource RegionBrush}">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="{Binding Label}"
                                 Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"
                                 VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="1" Text="{Binding Value}" TextWrapping="Wrap"
                                 FontSize="12" FontWeight="SemiBold"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </hc:Card>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Grid>
</hc:Window>
