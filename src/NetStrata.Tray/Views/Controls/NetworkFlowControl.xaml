<UserControl x:Class="NetStrata.Tray.Views.Controls.NetworkFlowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="200">
  <StackPanel>
    <TextBlock x:Name="HeaderTitle" FontSize="15" FontWeight="SemiBold"
               Text="监控目标（点击展开）"/>
    <TextBlock x:Name="HeaderHint" Margin="0,4,0,12" FontSize="11"
               Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"
               Text="每个目标独立一块动画；折叠标题上直接写明该目标的流量出口（直连 / 代理）。"/>
    <StackPanel x:Name="EmptyPanel" Visibility="Collapsed" Margin="0,8,0,0">
      <TextBlock x:Name="EmptyText" FontSize="12"
                 Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"
                 Text="本轮采样尚无 HTTPS 监控目标。"/>
      <Button x:Name="EmptyProbeButton" Content="立即探测" Margin="0,12,0,0"
              HorizontalAlignment="Left" MinWidth="120" Height="36" Padding="14,6"
              Style="{DynamicResource ButtonPrimary}"
              Click="EmptyProbe_Click"/>
    </StackPanel>
    <StackPanel x:Name="BlocksHost"/>
  </StackPanel>
</UserControl>
