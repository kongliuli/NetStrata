<UserControl x:Class="NetStrata.Tray.Views.Controls.NetworkFlowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             MinHeight="430">
  <UserControl.Resources>
    <Style x:Key="FlowModeButton" TargetType="Button" BasedOn="{StaticResource ButtonDefault}">
      <Setter Property="MinHeight" Value="36"/>
      <Setter Property="MinWidth" Value="92"/>
      <Setter Property="Padding" Value="12,0"/>
      <Setter Property="Margin" Value="0,0,4,0"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="hc:BorderElement.CornerRadius" Value="6"/>
    </Style>
    <Style x:Key="FlowToolButton" TargetType="Button" BasedOn="{StaticResource ButtonDefault}">
      <Setter Property="MinHeight" Value="36"/>
      <Setter Property="MinWidth" Value="64"/>
      <Setter Property="Padding" Value="12,0"/>
      <Setter Property="Margin" Value="4,0,0,0"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="hc:BorderElement.CornerRadius" Value="6"/>
    </Style>
  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel>
        <TextBlock x:Name="FlowTitle" FontSize="15" FontWeight="SemiBold" Text="多层网络流转"/>
        <TextBlock x:Name="FlowDisclosure" Margin="0,4,0,0" FontSize="11"
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   Text="诊断结果重放，非逐包抓取" TextWrapping="Wrap"/>
      </StackPanel>
      <TextBlock x:Name="CapturedAtText" Grid.Column="1" Margin="12,2,0,0" FontSize="11"
                 Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Top"/>
    </Grid>

    <Grid Grid.Row="1" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <WrapPanel x:Name="ModeButtons" VerticalAlignment="Center">
        <Button x:Name="LayersModeButton" Content="分层诊断" Tag="Layers"
                Style="{StaticResource FlowModeButton}" Click="Mode_Click"/>
        <Button x:Name="RoutesModeButton" Content="直连 / 代理" Tag="Routes"
                Style="{StaticResource FlowModeButton}" Click="Mode_Click"/>
        <Button x:Name="TlsModeButton" Content="TLS 栈" Tag="Tls"
                Style="{StaticResource FlowModeButton}" Click="Mode_Click"/>
      </WrapPanel>
      <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
        <ComboBox x:Name="SpeedBox" Width="72" MinHeight="36" SelectedIndex="1"
                  AutomationProperties.Name="播放速度">
          <ComboBoxItem Content="0.5x" Tag="2"/>
          <ComboBoxItem Content="1x" Tag="1"/>
          <ComboBoxItem Content="2x" Tag="0.5"/>
        </ComboBox>
        <Button x:Name="PlayButton" Content="播放" Style="{StaticResource FlowToolButton}"
                Click="Play_Click" AutomationProperties.Name="播放诊断结果"/>
        <Button x:Name="ResetButton" Content="重置" Style="{StaticResource FlowToolButton}"
                Click="Reset_Click" AutomationProperties.Name="重置诊断结果"/>
      </WrapPanel>
    </Grid>

    <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
            Background="{DynamicResource RegionBrush}" CornerRadius="8" ClipToBounds="True">
      <Canvas x:Name="FlowCanvas" Height="320" MinHeight="320"
              SizeChanged="FlowCanvas_SizeChanged"/>
    </Border>

    <Border Grid.Row="3" Margin="0,8,0,0" Padding="10,8" CornerRadius="6"
            Background="{DynamicResource RegionBrush}">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left" Text="当前" Margin="0,0,10,0"
                   FontSize="11" FontWeight="SemiBold"/>
        <TextBlock x:Name="FlowStatus" FontSize="11" Text="等待诊断数据"
                   Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"
                   AutomationProperties.LiveSetting="Polite"/>
      </DockPanel>
    </Border>
  </Grid>
</UserControl>
