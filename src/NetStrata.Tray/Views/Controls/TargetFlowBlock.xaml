<UserControl x:Class="NetStrata.Tray.Views.Controls.TargetFlowBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             Margin="0,0,0,8">
  <UserControl.Resources>
    <Style x:Key="FlowToolButton" TargetType="Button" BasedOn="{StaticResource ButtonDefault}">
      <Setter Property="MinHeight" Value="32"/>
      <Setter Property="MinWidth" Value="56"/>
      <Setter Property="Padding" Value="10,0"/>
      <Setter Property="Margin" Value="4,0,0,0"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="hc:BorderElement.CornerRadius" Value="6"/>
    </Style>
  </UserControl.Resources>

  <Border x:Name="CardBorder" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8"
          Background="{DynamicResource RegionBrush}">
    <Expander x:Name="RootExpander" IsExpanded="False" BorderThickness="0"
              Expanded="RootExpander_Expanded" Collapsed="RootExpander_Collapsed">
      <Expander.Header>
        <DockPanel Margin="0,2,8,2">
          <Border x:Name="OutcomeDot" DockPanel.Dock="Left" Width="8" Height="8" CornerRadius="4"
                  Margin="0,0,10,0" VerticalAlignment="Center"
                  Background="{DynamicResource NsStatusSkippedBrush}"/>
          <Border x:Name="BadgeBorder" DockPanel.Dock="Right" Padding="7,2" CornerRadius="10"
                  Margin="8,0,0,0" VerticalAlignment="Top" BorderThickness="1">
            <TextBlock x:Name="BadgeText" FontSize="10" FontWeight="SemiBold"/>
          </Border>
          <StackPanel>
            <TextBlock x:Name="TitleText" FontWeight="SemiBold" FontSize="13"/>
            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
              <TextBlock x:Name="EgressText" FontSize="11"
                         Foreground="{DynamicResource PrimaryBrush}" TextWrapping="Wrap"/>
              <Border x:Name="EgressFlipBadge" Margin="8,0,0,0" Padding="6,1" CornerRadius="8"
                      Background="{DynamicResource NsStatusDegradedSoftBrush}"
                      BorderBrush="{DynamicResource NsStatusDegradedBrush}" BorderThickness="1"
                      Visibility="Collapsed" VerticalAlignment="Center">
                <TextBlock x:Name="EgressFlipText" Text="出口已切换 ⇄" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource NsStatusDegradedBrush}"/>
              </Border>
            </StackPanel>
            <TextBlock x:Name="SummaryText" Margin="0,2,0,0" FontSize="11"
                       Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
          </StackPanel>
        </DockPanel>
      </Expander.Header>

      <StackPanel Margin="4,0,4,10">
        <DockPanel Margin="0,0,0,8">
          <TextBlock x:Name="HintText" DockPanel.Dock="Left" VerticalAlignment="Center"
                     FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                     Text="该目标独立路径（底层 → 本目标出口 → 目标）"/>
          <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
            <ComboBox x:Name="SpeedBox" Width="68" MinHeight="32" SelectedIndex="1">
              <ComboBoxItem Content="0.5x" Tag="2"/>
              <ComboBoxItem Content="1x" Tag="1"/>
              <ComboBoxItem Content="2x" Tag="0.5"/>
            </ComboBox>
            <Button x:Name="PlayButton" Content="重放" Style="{StaticResource FlowToolButton}"
                    Click="Play_Click"/>
            <Button Content="重置" Style="{StaticResource FlowToolButton}" Click="Reset_Click"/>
            <Button x:Name="TrendButton" Content="趋势" Style="{StaticResource FlowToolButton}"
                    Click="Trend_Click" ToolTip="在历史趋势页查看"/>
          </WrapPanel>
        </DockPanel>
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6"
                Background="{DynamicResource SecondaryRegionBrush}" ClipToBounds="True">
          <Canvas x:Name="FlowCanvas" Height="200" MinHeight="180"
                  SizeChanged="FlowCanvas_SizeChanged"/>
        </Border>
        <TextBlock x:Name="StatusText" Margin="0,8,0,0" FontSize="11"
                   Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
      </StackPanel>
    </Expander>
  </Border>
</UserControl>
